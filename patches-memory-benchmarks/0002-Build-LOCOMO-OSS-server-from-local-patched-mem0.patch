From 15e1982d315998ad3e115ebf9d91a8a5f7dca45a Mon Sep 17 00:00:00 2001
From: YingzuoLiu <yingzuoliu@gmail.com>
Date: Wed, 8 Jul 2026 20:06:31 +0800
Subject: [PATCH 2/2] Build LOCOMO OSS server from local patched mem0

---
 docker-compose.yml           |  3 ++-
 docker/mem0/Dockerfile       | 24 +++++++++++++++++-------
 docker/mem0/requirements.txt |  1 -
 3 files changed, 19 insertions(+), 9 deletions(-)

diff --git a/docker-compose.yml b/docker-compose.yml
index 3d5d5ad..da57fd0 100644
--- a/docker-compose.yml
+++ b/docker-compose.yml
@@ -1,7 +1,8 @@
 services:
   mem0:
     build:
-      context: ./docker/mem0
+      context: ..
+      dockerfile: memory-benchmarks/docker/mem0/Dockerfile
     ports:
       - "${MEM0_PORT:-8888}:8000"
     depends_on:
diff --git a/docker/mem0/Dockerfile b/docker/mem0/Dockerfile
index 0a210f9..073de80 100644
--- a/docker/mem0/Dockerfile
+++ b/docker/mem0/Dockerfile
@@ -2,25 +2,35 @@ FROM python:3.12-slim
 
 WORKDIR /app
 
-# System deps for spaCy native extensions
+# System deps for spaCy native extensions and local editable install
 RUN apt-get update && \
     apt-get install -y --no-install-recommends build-essential git && \
     rm -rf /var/lib/apt/lists/*
 
-COPY requirements.txt .
+COPY memory-benchmarks/docker/mem0/requirements.txt .
 RUN pip install --no-cache-dir -r requirements.txt
 
-# Download spaCy English model (used for entity extraction + lemmatization)
+# Install the local patched mem0 checkout from the workspace build context.
+COPY mem0 /opt/mem0
+RUN pip install --no-cache-dir -e /opt/mem0
+
+# Download spaCy English model, used for entity extraction + lemmatization.
 RUN python -m spacy download en_core_web_sm
 
-# Allow "sagemaker" as an embedding provider in mem0's config validator
-RUN sed -i 's/"aws_bedrock",/"aws_bedrock", "sagemaker",/' \
-    /usr/local/lib/python3.12/site-packages/mem0/embeddings/configs.py
+# Allow "sagemaker" as an embedding provider in mem0's config validator.
+RUN python - <<'PY'
+from pathlib import Path
+
+path = Path("/opt/mem0/mem0/embeddings/configs.py")
+text = path.read_text()
+text = text.replace('"aws_bedrock",', '"aws_bedrock", "sagemaker",')
+path.write_text(text)
+PY
 
 # History directory
 RUN mkdir -p /app/history
 
-COPY . .
+COPY memory-benchmarks/docker/mem0 .
 
 EXPOSE 8000
 
diff --git a/docker/mem0/requirements.txt b/docker/mem0/requirements.txt
index 6905e88..cee1b16 100644
--- a/docker/mem0/requirements.txt
+++ b/docker/mem0/requirements.txt
@@ -1,6 +1,5 @@
 fastapi>=0.115.0
 uvicorn>=0.34.0
-mem0ai @ git+https://github.com/mem0ai/mem0.git@feat/v3-pipeline
 spacy>=3.7.0
 pydantic>=2.10.0
 pyyaml>=6.0
