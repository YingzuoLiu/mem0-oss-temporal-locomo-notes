+def _parse_temporal_datetime(value):
+    """Best-effort parse for ISO-like timestamps used in memory payloads."""
+    if value is None:
+        return None
+    if isinstance(value, datetime):
+        parsed = value
+    else:
+        try:
+            parsed = datetime.fromisoformat(str(value).replace("Z", "+00:00"))
+        except (TypeError, ValueError):
+            return None
+
+    if parsed.tzinfo is None:
+        return parsed.replace(tzinfo=timezone.utc)
+    return parsed.astimezone(timezone.utc)
+
+
+def _infer_temporal_rank_direction(query):
+    """Infer whether a query is asking for latest/recent or earliest/first memories."""
+    q = (query or "").lower()
+
+    earliest_terms = (
+        "earliest",
+        "oldest",
+        "first",
+        "initial",
+        "originally",
+    )
+    latest_terms = (
+        "latest",
+        "newest",
+        "most recent",
+        "recent",
+        "recently",
+        "current",
+        "now",
+        "last time",
+    )
+
+    if any(term in q for term in earliest_terms):
+        return "asc"
+    if any(term in q for term in latest_terms):
+        return "desc"
+    return None
+
+
+def _apply_reference_date_temporal_rerank(query, memories, reference_date, explain=False):
+    """Apply a conservative temporal rerank for explicitly temporal recency/order queries.
+
+    This does not hard-filter results. For latest/recent queries, memories at or before
+    reference_date are preferred by recency, while future-dated memories are kept after them.
+    """
+    if reference_date is None or not memories:
+        return memories
+
+    direction = _infer_temporal_rank_direction(query)
+    if direction is None:
+        return memories
+
+    reference_dt = _parse_temporal_datetime(reference_date)
+    dated = []
+    missing = []
+
+    for item in memories:
+        created_at = item.get("created_at")
+        if created_at is None and isinstance(item.get("metadata"), dict):
+            created_at = item["metadata"].get("created_at") or item["metadata"].get("timestamp")
+        created_dt = _parse_temporal_datetime(created_at)
+
+        if created_dt is None:
+            missing.append(item)
+        else:
+            dated.append((created_dt, item))
+
+    if not dated:
+        return memories
+
+    if direction == "desc" and reference_dt is not None:
+        before_or_equal = [(dt, item) for dt, item in dated if dt <= reference_dt]
+        after = [(dt, item) for dt, item in dated if dt > reference_dt]
+        before_or_equal.sort(key=lambda pair: pair[0], reverse=True)
+        after.sort(key=lambda pair: pair[0])
+        ordered = [item for _, item in before_or_equal] + [item for _, item in after] + missing
+    else:
+        dated.sort(key=lambda pair: pair[0], reverse=(direction == "desc"))
+        ordered = [item for _, item in dated] + missing
+
+    if explain:
+        for rank, item in enumerate(ordered):
+            item.setdefault("score_details", {})
+            item["score_details"]["temporal_rerank"] = {
+                "rank": rank,
+                "direction": direction,
+                "reference_date": reference_date,
+                "created_at": item.get("created_at"),
+            }
+
+    return ordered
+
