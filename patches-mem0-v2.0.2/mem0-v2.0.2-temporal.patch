+def _parse_temporal_datetime(value):
+    """Best-effort parse for ISO-like timestamps used in memory payloads."""
+    if value is None:
+        return None
+    if isinstance(value, datetime):
+        parsed = value
+    else:
+        try:
+            parsed = datetime.fromisoformat(str(value).replace("Z", "+00:00"))
+        except (TypeError, ValueError):
+            return None
+
+    if parsed.tzinfo is None:
+        return parsed.replace(tzinfo=timezone.utc)
+    return parsed.astimezone(timezone.utc)
+
+
+def _contains_temporal_phrase(query: str, terms: tuple[str, ...]) -> bool:
+    """Match temporal trigger terms with word boundaries to avoid substring false positives.
+
+    For example, "now" should not match inside "known".
+    """
+    q = f" {query or ''} ".lower()
+    for term in terms:
+        pattern = r"(?<![a-z0-9])" + re.escape(term.lower()) + r"(?![a-z0-9])"
+        if re.search(pattern, q):
+            return True
+    return False
+
+
+def _infer_temporal_rank_direction(query):
+    """Infer temporal intent from a search query.
+
+    Returns:
+        "asc": earliest/first-style ordering
+        "desc": latest/recent/current-style ordering
+        "context": temporal relationship query without a clear sort direction
+        None: no obvious temporal intent
+    """
+    q = (query or "").lower()
+
+    earliest_terms = (
+        "earliest",
+        "oldest",
+        "first",
+        "initial",
+        "originally",
+    )
+    latest_terms = (
+        "latest",
+        "newest",
+        "most recent",
+        "recent",
+        "recently",
+        "current",
+        "currently",
+        "now",
+        "last time",
+    )
+    temporal_context_terms = (
+        "before",
+        "after",
+        "when",
+        "while",
+        "during",
+        "since",
+        "until",
+        "by the time",
+        "at the time",
+        "how long",
+        "how many days",
+        "how many weeks",
+        "how many months",
+        "how many years",
+        "prior",
+        "previous",
+        "previously",
+        "earlier",
+        "later",
+        "then",
+        "date",
+        "time",
+        "moved",
+        "move",
+        "occurred",
+        "happened",
+        "started",
+        "ended",
+        "finished",
+        "began",
+    )
+
+    if _contains_temporal_phrase(q, earliest_terms):
+        return "asc"
+    if _contains_temporal_phrase(q, latest_terms):
+        return "desc"
+    if _contains_temporal_phrase(q, temporal_context_terms):
+        return "context"
+    return None
+
+
+def _apply_reference_date_temporal_rerank(query, memories, reference_date, explain=False):
+    """Apply conservative additive temporal scoring for temporal queries.
+
+    This does not hard-filter results. It adjusts each candidate's score using
+    the memory created_at timestamp, then sorts by the adjusted score. The goal is
+    to preserve semantic relevance while giving dated memories a small temporal
+    preference when the query has temporal intent.
+    """
+    if reference_date is None or not memories:
+        return memories
+
+    direction = _infer_temporal_rank_direction(query)
+    if direction is None:
+        return memories
+
+    reference_dt = _parse_temporal_datetime(reference_date)
+    dated = []
+    missing = []
+
+    for idx, item in enumerate(memories):
+        created_at = item.get("created_at")
+        if created_at is None and isinstance(item.get("metadata"), dict):
+            created_at = item["metadata"].get("created_at") or item["metadata"].get("timestamp")
+        created_dt = _parse_temporal_datetime(created_at)
+
+        if created_dt is None:
+            missing.append((idx, item))
+        else:
+            dated.append((idx, created_dt, item))
+
+    if not dated:
+        return memories
+
+    boosts = {}
+    # Keep temporal scoring as a small additive bias so semantic relevance remains dominant.
+    weight = 0.05 if direction in ("asc", "desc") else 0.025
+
+    if direction == "desc":
+        if reference_dt is not None:
+            before_or_equal = [(idx, dt, item) for idx, dt, item in dated if dt <= reference_dt]
+            after = [(idx, dt, item) for idx, dt, item in dated if dt > reference_dt]
+            before_or_equal.sort(key=lambda row: row[1], reverse=True)
+            after.sort(key=lambda row: row[1])
+            ranked = before_or_equal + after
+            preferred_count = max(len(before_or_equal), 1)
+            for rank, (idx, dt, item) in enumerate(ranked):
+                if dt <= reference_dt:
+                    boosts[idx] = weight * (preferred_count - min(rank, preferred_count - 1)) / preferred_count
+                else:
+                    boosts[idx] = -weight / 2
+        else:
+            ranked = sorted(dated, key=lambda row: row[1], reverse=True)
+            total = len(ranked)
+            for rank, (idx, dt, item) in enumerate(ranked):
+                boosts[idx] = weight * (total - rank) / total
+
+    elif direction == "asc":
+        ranked = sorted(dated, key=lambda row: row[1])
+        total = len(ranked)
+        for rank, (idx, dt, item) in enumerate(ranked):
+            boosts[idx] = weight * (total - rank) / total
+
+    else:
+        for idx, dt, item in dated:
+            if reference_dt is None or dt <= reference_dt:
+                boosts[idx] = weight
+            else:
+                boosts[idx] = -weight / 2
+
+    adjusted = []
+    for idx, item in enumerate(memories):
+        try:
+            base_score = float(item.get("score", 0) or 0)
+        except (TypeError, ValueError):
+            base_score = 0.0
+
+        temporal_score = boosts.get(idx, 0.0)
+        adjusted_score = base_score + temporal_score
+        item["score"] = adjusted_score
+
+        if explain:
+            item.setdefault("score_details", {})
+            item["score_details"]["temporal_rerank"] = {
+                "direction": direction,
+                "reference_date": reference_date,
+                "created_at": (
+                    (item.get("metadata") or {}).get("created_at")
+                    or (item.get("metadata") or {}).get("timestamp")
+                    or item.get("created_at")
+                    or item.get("timestamp")
+                ),
+                "base_score": base_score,
+                "temporal_score": temporal_score,
+                "adjusted_score": adjusted_score,
+            }
+
+        adjusted.append(item)
+
+    adjusted.sort(key=lambda item: item.get("score", 0), reverse=True)
+    return adjusted
+
+
+def _normalize_expiration_date(value: Any) -> Optional[str]:
+    if value is None:
+        return None
+    if isinstance(value, datetime):
+        return value.date().isoformat()
+    if isinstance(value, date):
+        return value.isoformat()
+    if isinstance(value, str):
+        try:
+            return date.fromisoformat(value).isoformat()
+        except ValueError as exc:
+            raise ValueError("expiration_date must be a valid date in YYYY-MM-DD format.") from exc
+    raise ValueError("expiration_date must be a date string in YYYY-MM-DD format.")
+
+
+def _payload_is_expired(payload: Optional[Dict[str, Any]]) -> bool:
+    if not payload:
+        return False
+    expiration_date = payload.get("expiration_date")
+    if not expiration_date:
+        return False
+    try:
+        return date.fromisoformat(str(expiration_date)) < datetime.now(timezone.utc).date()
+    except ValueError:
+        return False
+
+
