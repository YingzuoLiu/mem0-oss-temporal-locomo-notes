+def _contains_temporal_phrase(query: str, terms: tuple[str, ...]) -> bool:
+    """Match temporal trigger terms with word boundaries to avoid substring false positives.
+
+    For example, "now" should not match inside "known".
+    """
+    q = f" {query or ''} ".lower()
+    for term in terms:
+        pattern = r"(?<![a-z0-9])" + re.escape(term.lower()) + r"(?![a-z0-9])"
+        if re.search(pattern, q):
+            return True
+    return False
+
