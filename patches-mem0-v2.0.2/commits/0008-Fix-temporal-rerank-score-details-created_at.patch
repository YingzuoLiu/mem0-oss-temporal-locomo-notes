index 1753981d..4f7378e4 100644
--- a/mem0/memory/main.py
+++ b/mem0/memory/main.py
@@ -547,7 +547,12 @@ def _apply_reference_date_temporal_rerank(query, memories, reference_date, expla
             item["score_details"]["temporal_rerank"] = {
                 "direction": direction,
                 "reference_date": reference_date,
-                "created_at": item.get("created_at"),
+                "created_at": (
+                    (item.get("metadata") or {}).get("created_at")
